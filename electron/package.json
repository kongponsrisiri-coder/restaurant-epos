{
  "name": "siamepos-electron",
  "version": "1.5.2",
  "description": "SiamEPOS Pro desktop shell — offline-capable EPOS for Thai restaurants",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:dev": "ELECTRON_DEV=1 electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:all": "electron-builder -mwl --publish never",
    "rebuild:native": "node scripts/rebuild-native.js"
  },
  "build": {
    "appId": "uk.co.siamepos.pro",
    "productName": "SiamEPOS",
    "artifactName": "${productName} Setup.${ext}",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**"
    ],
    "extraResources": [
      { "from": "../client/dist",     "to": "client-dist" },
      { "from": "../src",             "to": "src" },
      { "from": "../package.json",    "to": "package.json" },
      {
        "from": "../node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/.DS_Store",
          "!**/{test,tests,docs,doc,example,examples}/**",
          "!**/*.md",
          "!**/*.markdown",
          "!**/{.bin,.cache,.github,.vscode}/**"
        ]
      }
    ],
    "mac": {
      "icon": "../client/public/icon-512.png",
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "category": "public.app-category.business"
    },
    "dmg": {
      "title": "SiamEPOS Setup"
    },
    "win": {
      "icon": "../client/public/icon-512.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SiamEPOS"
    },
    "publish": [{
      "provider": "github",
      "owner": "kongponsrisiri-coder",
      "repo": "restaurant-epos",
      "releaseType": "release"
    }]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "qrcode": "^1.5.4"
  }
}
